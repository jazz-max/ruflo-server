# Ruflo MCP Server
RUFLO_PORT=3000

# PostgreSQL
POSTGRES_DB=ruflo
POSTGRES_USER=ruflo
POSTGRES_PASSWORD=changeme

# Volume: internal (default) or external path
# Internal (Docker volume):
#   POSTGRES_DATA=ruflo-pgdata
# External (host directory):
#   POSTGRES_DATA=/path/to/data/on/host
POSTGRES_DATA=ruflo-pgdata
